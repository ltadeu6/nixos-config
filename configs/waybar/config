{
    "layer": "top",
    "position": "top",
    "fixed-center": true,
    "height": 48,
    "margin-top": 20,
    "margin-bottom": 0,
    "output": ["DP-5", "DP-3"],
    "modules-left": ["hyprland/workspaces", "cava"],
    "modules-center": ["custom/ac", "clock"],
    "modules-right": [
        "mpris",
        "network",
        "bluetooth",
        "pulseaudio",
        "backlight",
        "battery",
        "custom/poweroff"
    ],
    "group/power": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "transition-left-to-right": false
        },
        "modules": [
            "custom/poweroff",
            "custom/restart",
            "custom/exit",
            "custom/sleep",
            "custom/lock"
        ]
    },
    "custom/poweroff": {
        "format": "´Çæ",
        "on-click": "poweroff"
    },
    "custom/restart": {
        "format": "¾░æÉ",
        "on-click": "reboot"
    },
    "custom/exit": {
        "format": "¾░ù╝",
        "on-click": "hyprctl dispatch exit"
    },
    "custom/sleep": {
        "format": "¾░ñä",
        "on-click": "systemctl suspend"
    },
    "custom/lock": {
        "format": "¯»º",
        "on-click": "hyprlock"
    },
    "custom/kde": {
        "format": "´äï",
        "on-click": "hyprlock"
    },
    "hyprland/workspaces": {
        "all-outputs": false,
        "active-only": false,
        "persistent-workspaces": {
            "DP-3": [1, 2, 3, 4, 5, 6, 7, 8, 9],
            "DP-5": [1, 2, 3, 4, 5, 6, 7, 8, 9],
            "HDMI-A-1": [10]
        },
        "format": "{icon}",
        "format-icons": {
            "1": "´ë®",
            "2": "¯ÿ▓",
            "3": "´Æë",
            "4": "¾░»ë",
            "5": "¾░¡╣",
            "6": "¯£Ä",
            "7": "´Ç¥",
            "8": "´Çü",
            "9": "´Ç¢",
            "10": "´å╝"
        },
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1"
    },
    "clock": {
        "format": "{:%d/%m/%Y - %H:%M}",
        "tooltip": false,
        "locale": "pt_BR.utf8"
    },
    "cpu": {
        "interval": 5,
        "format": "´ïø´©ü {}%",
        "max-length": 10
    },
    "cava": {
        "framerate": 60,
        "hide_on_silence": true,
        "bars": 10,
        "source": "auto",
        "method": "pipewire",
        "stereo": true,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": true,
        "noise_reduction": 0.2,
        "sleep_timer": 1,
        "input_delay": 0,
        "format-icons": ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"],
        "actions": {
            "on-click-right": "mode"
        }
    },
    "memory": {
        "interval": 15,
        "format": "´ö©´©ü {used:0.1f}G/{total:0.1f}G",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-muted": "´Çª",
        "format-icons": {
            "alsa_output.pci-0000_05_00.6.analog-stereo": "¾░ïï",
            "analog-output-lineout": "¾░ïï",
            "analog-output-headphones": "¾░ïï",
            "Ryzen HD Audio Controller": "¾░ïï",
            // "headphone": "¾░ïï",
            // "hands-free": "¾░ïï",
            // "headset": "¾▒íÆ",
            // "phone": "´éò",
            // "portable": "´éò",
            // "car": "´å╣",
            "default": ["¾░ò┐", "¾░ûÇ", "¾░ûÇ", "¾░ò¥", "¾░ò¥", "¾░ò¥"]
        },
        "scroll-step": 10,
        "on-click": "pavucontrol",
        "on-click-right": "$HOME/nixos-config/configs/waybar/switch_sink.sh",
        "ignored-sinks": ["Easy Effects Sink"],
        "tooltip-format": "{icon} {volume}"
    },
    "bluetooth": {
        "format": "¾░é»",
        "format-connected": "¾░é▒",
        "format-connected-battery": "¾░é▒",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "bluetoothctl disconnect",
        "on-click-right": "bluetoothctl connect B6:97:1A:3D:6A:B2"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "scroll-step": 5,
        "format-icons": ["¾░âø", "¾░â£", "¾░âØ", "¾░â×", "¾░âƒ", "¾░âá"]
    },
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} {dynamic}",
        "tooltip-format": "{status_icon} {dynamic}",
        "player-icons": {
            "default": "¯¼¼",
            "mpv": "­ƒÄÁ"
        },
        "status-icons": {
            "paused": "¯½æ"
        },
        "dynamic-len": 40,
        "dynamic-order": ["title", "artist", "album"],
        "player": "spotify",
        "ignored-players": ["firefox*"],
        "on-scroll-up": "playerctl -i firefox volume 0.1+",
        "on-scroll-down": "playerctl -i firefox volume 0.1-"
    },
    "battery": {
        "format": "{icon} ",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
        "format-charging": "{icon}",
        "format-full": "{icon}",
        "interval": 15,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": false
    },
    "network": {
        "format": "{icon}",
        "format-alt": "¾░▓Ø {ipaddr}",
        "format-alt-click": "click-left",
        "format-wifi": "´ç½ ",
        "format-ethernet": "¾░▓Ø",
        "format-disconnected": "ÔÜá",
        "tooltip": false
    },
    "custom/ac": {
    "exec": "$HOME/nixos-config/configs/waybar/air_control.py",
    "interval": 3,
    "return-type": "json",
    "markup": "true",
    "on-click": "$HOME/nixos-config/configs/waybar/air_control.py toggle",
    "on-click-right": "$HOME/nixos-config/configs/waybar/air_control.py cycle-mode",
    "on-click-middle": "$HOME/nixos-config/configs/waybar/air_control.py cycle-fan",
    "on-scroll-up": "$HOME/nixos-config/configs/waybar/air_control.py up",
    "on-scroll-down": "$HOME/nixos-config/configs/waybar/air_control.py down"
}
}
